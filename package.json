{
  "name": "rustcode",
  "version": "0.1.3",
  "description": "RustCode TUI distributed via npm with prebuilt binaries",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KonshinHaoshin/claude-code-rust.git"
  },
  "homepage": "https://github.com/KonshinHaoshin/claude-code-rust#readme",
  "bugs": {
    "url": "https://github.com/KonshinHaoshin/claude-code-rust/issues"
  },
  "bin": {
