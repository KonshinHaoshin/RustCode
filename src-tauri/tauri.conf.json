{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RustCode",
  "version": "0.1.0",
  "identifier": "com.konshinhaoshin.rustcode",
  "build": {
    "beforeDevCommand": "pnpm --dir ./gui dev --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "pnpm --dir ./gui build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "./gui/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "RustCode",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
